    "weights_ = scratch_model.weights\n",
    "colors_fi = ['#51cf66' if w > 0 else '#ff6b6b' for w in weights_]\n",
    "\n",
    "sorted_idx = np.argsort(np.abs(weights_))[::-1]\n",
    "sorted_feat = [feature_cols[i] for i in sorted_idx]\n",
    "sorted_w    = weights_[sorted_idx]\n",
    "sorted_colors = [colors_fi[i] for i in sorted_idx]\n",
    "\n",
    "bars = ax.barh(sorted_feat, sorted_w, color=sorted_colors,\n",
    "               edgecolor='none', height=0.6)\n",
    "ax.axvline(0, color='white', linewidth=1.2, alpha=0.5)\n",
    "\n",
    "for bar, val in zip(bars, sorted_w):\n",
    "    ax.text(val + (0.002 if val >= 0 else -0.002),\n",
    "            bar.get_y() + bar.get_height()/2,\n",
    "            f'{val:.4f}', va='center',\n",
    "            ha='left' if val >= 0 else 'right',\n",
    "            color='white', fontsize=9)\n",
    "\n",
    "ax.set_title('⚖️ Perceptron Feature Weights (Importance)', color='white', fontsize=14, pad=15)\n",
