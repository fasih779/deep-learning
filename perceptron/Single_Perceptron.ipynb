    "# ── Plot 8: 2D Decision Boundary (CGPA vs IQ) ──────────────────────────────\n",
    "fig, ax = plt.subplots(figsize=(10, 7))\n",
    "fig.patch.set_facecolor('#0d1117')\n",
    "ax.set_facecolor('#161b22')\n",
    "\n",
    "# Use only 2 features for 2D visualization\n",
    "X2 = df[['IQ', 'CGPA']].values\n",
    "y2 = df['Placement'].values\n",
    "\n",
    "X2_train, X2_test, y2_train, y2_test = train_test_split(X2, y2, test_size=0.2, random_state=42)\n",
    "sc2 = StandardScaler()\n",
    "X2_train_sc = sc2.fit_transform(X2_train)\n",
    "X2_test_sc  = sc2.transform(X2_test)\n",
    "\n",
    "model2d = SinglePerceptron(learning_rate=0.1, n_iterations=200)\n",
    "model2d.fit(X2_train_sc, y2_train)\n",
    "\n",
    "# Create meshgrid\n",
    "h = 0.05\n",
    "x_min, x_max = X2_train_sc[:, 0].min() - 1, X2_train_sc[:, 0].max() + 1\n",
    "y_min, y_max = X2_train_sc[:, 1].min() - 1, X2_train_sc[:, 1].max() + 1\n",
    "xx, yy = np.meshgrid(np.arange(x_min, x_max, h),\n",
    "                     np.arange(y_min, y_max, h))\n",
    "Z = model2d.predict(np.c_[xx.ravel(), yy.ravel()])\n",
    "Z = Z.reshape(xx.shape)\n",
    "\n",
    "ax.contourf(xx, yy, Z, alpha=0.25, colors=['#ff6b6b', '#51cf66'])\n",
    "ax.contour(xx, yy, Z, colors=['white'], linewidths=2, linestyles='--')\n",
    "\n",
    "# Scatter plot\n",
    "ax.scatter(X2_train_sc[y2_train==0, 0], X2_train_sc[y2_train==0, 1],\n",
    "           c='#ff6b6b', edgecolors='white', lw=0.5, s=60, label='Not Placed', alpha=0.8, zorder=3)\n",
    "ax.scatter(X2_train_sc[y2_train==1, 0], X2_train_sc[y2_train==1, 1],\n",
    "           c='#51cf66', edgecolors='white', lw=0.5, s=60, label='Placed', alpha=0.8, zorder=3)\n",
    "\n",
    "acc2d = accuracy_score(y2_test, model2d.predict(X2_test_sc))\n",
    "ax.set_title(f'🎯 Decision Boundary: IQ vs CGPA\\n(2D Perceptron Acc: {acc2d*100:.1f}%)',\n",
    "             color='white', fontsize=13, pad=15)\n",
    "ax.set_xlabel('IQ (scaled)', color='#8b949e', fontsize=11)\n",
    "ax.set_ylabel('CGPA (scaled)', color='#8b949e', fontsize=11)\n",
    "ax.tick_params(colors='#8b949e')\n",
    "ax.spines[['top','right','left','bottom']].set_color('#30363d')\n",
    "ax.legend(facecolor='#21262d', labelcolor='white', fontsize=11)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('plots/08_decision_boundary.png', bbox_inches='tight', facecolor='#0d1117')\n",
    "plt.show()\n",
    "print(\"📌 Decision boundary plotted!\")"
